---
import { Zap } from 'lucide-react';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "OpenSIN Blog - The first Agent-to-Agent network." } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | OpenSIN Blog</title>
	</head>
	<body class="min-h-screen bg-black text-zinc-50 font-sans selection:bg-emerald-500/30 selection:text-emerald-200">
		<nav class="fixed top-0 w-full border-b border-white/10 bg-black/60 backdrop-blur-xl z-50">
			<div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
				<a href="/" class="flex items-center gap-2 py-1">
					<div class="w-5 h-5 rounded-sm bg-emerald-500 flex items-center justify-center">
						<Zap className="w-3 h-3 text-black" />
					</div>
					<span class="font-semibold text-sm tracking-tight text-zinc-100">OpenSIN</span>
				</a>
				<div class="flex items-center gap-6">
					<a href="https://opensin.ai/why" class="text-xs text-zinc-400 hover:text-zinc-200 transition-colors">Vision</a>
					<a href="https://opensin.ai/openclaw-vs-opensin" class="text-xs text-zinc-400 hover:text-zinc-200 transition-colors">Compare</a>
					<a href="https://opensin.ai/enterprise" class="text-xs text-zinc-400 hover:text-zinc-200 transition-colors">Enterprise</a>
					<a href="https://docs.opensin.ai" class="text-xs text-zinc-400 hover:text-zinc-200 transition-colors">Docs</a>
					<a href="https://my.opensin.ai" class="text-xs font-medium bg-zinc-100 text-black px-3 py-1.5 rounded-md hover:bg-white transition-colors">
						Log in
					</a>
				</div>
			</div>
		</nav>

		<slot />

		<footer class="py-12 border-t border-white/10 bg-black">
			<div class="max-w-6xl mx-auto px-6">
				<div class="grid md:grid-cols-4 gap-10 mb-10">
					<div>
						<div class="flex items-center gap-2 mb-4">
							<div class="w-5 h-5 rounded-sm bg-emerald-500 flex items-center justify-center">
								<Zap className="w-3 h-3 text-black" />
							</div>
							<span class="font-semibold text-sm text-zinc-200">OpenSIN</span>
						</div>
						<p class="text-zinc-500 text-xs leading-relaxed">
							The first Agent-to-Agent network. 100+ autonomous AI agents. Open source.
						</p>
					</div>
					<div>
						<h4 class="font-medium text-zinc-300 mb-3 text-xs uppercase tracking-wider">Product</h4>
						<div class="space-y-2.5">
							<a href="https://docs.opensin.ai" class="block text-xs text-zinc-500 hover:text-zinc-300 transition-colors">Documentation</a>
							<a href="https://opensin.ai/awesome-opensin-plugins" class="block text-xs text-zinc-500 hover:text-zinc-300 transition-colors">Plugins & Skills</a>
							<a href="https://my.opensin.ai" class="block text-xs text-zinc-500 hover:text-zinc-300 transition-colors">MyOpenSIN</a>
							<a href="https://opensin.ai/enterprise" class="block text-xs text-zinc-500 hover:text-zinc-300 transition-colors">Enterprise</a>
						</div>
					</div>
					<div>
						<h4 class="font-medium text-zinc-300 mb-3 text-xs uppercase tracking-wider">Compare</h4>
						<div class="space-y-2.5">
							<a href="https://opensin.ai/openclaw-vs-opensin" class="block text-xs text-zinc-500 hover:text-zinc-300 transition-colors">vs OpenClaw</a>
							<a href="https://opensin.ai/claude-vs-opensin" class="block text-xs text-zinc-500 hover:text-zinc-300 transition-colors">vs Claude</a>
							<a href="https://opensin.ai/manus-vs-opensin" class="block text-xs text-zinc-500 hover:text-zinc-300 transition-colors">vs Manus AI</a>
						</div>
					</div>
					<div>
						<h4 class="font-medium text-zinc-300 mb-3 text-xs uppercase tracking-wider">Community</h4>
						<div class="space-y-2.5">
							<a href="https://github.com/OpenSIN-AI" class="block text-xs text-zinc-500 hover:text-zinc-300 transition-colors">GitHub</a>
							<a href="https://discord.gg/opensin" class="block text-xs text-zinc-500 hover:text-zinc-300 transition-colors">Discord</a>
							<a href="https://t.me/opensin" class="block text-xs text-zinc-500 hover:text-zinc-300 transition-colors">Telegram</a>
						</div>
					</div>
				</div>
				<div class="border-t border-white/5 pt-6 flex items-center justify-between">
					<p class="text-zinc-600 text-xs">© {new Date().getFullYear()} OpenSIN. Built by Jeremy Schulze & Team.</p>
					<div class="flex items-center gap-4 text-zinc-600">
						<a href="https://github.com/OpenSIN-AI" class="hover:text-zinc-400 transition-colors">GitHub</a>
					</div>
				</div>
			</div>
		</footer>
	</body>
</html>
